# Supabase (public read-only for web)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Revalidate (call from CI/webhook; use header x-revalidate-secret)
REVALIDATION_SECRET=your-secret

# Resend (send-email API)
RESEND_API_KEY=re_xxxx
# Optional: custom from address after verifying domain in Resend
# SEND_EMAIL_FROM=StoreLink <noreply@storelink.ng>

# App store links (insert when live; optional until then)
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/app/...
# NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=...

# Admin dashboard (redirect /admin to this URL)
# NEXT_PUBLIC_ADMIN_APP_URL=https://admin.storelink.ng

# Seller storefront on storelink.ng/sell — rewrite to your storefront Vercel deployment (no trailing slash).
# The storefront Next app uses basePath `/sell`. Add both projects to the same Vercel team; set this to the storefront production URL.
# STOREFRONT_ORIGIN=https://store-link-storefront-xxxx.vercel.app

# Optional: only if this Next app embeds Maps / Places (marketing site usually omits this)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Paystack — Nigeria primary; add regional keys when expanding checkout.
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
